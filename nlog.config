<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true">

	<!-- enable asp.net core layout renderers -->
	<!--<extensions>
		<add assembly="NLog.Web.AspNetCore"/>
	</extensions>-->

	<!-- the targets to write to -->
	<targets>
		<!-- File Target for all log messages with basic details -->
		<target xsi:type="File" name="latestLog" fileName="./latest.log"
				layout="[${longdate}] [${level}] [${logger}] (${event-properties:item=EventId:whenEmpty=0}) ${message} ${exception:format=tostring}" />
		<target xsi:type="Console" name="console"
				layout="[${longdate}] [${level}] [${logger}] (${event-properties:item=EventId:whenEmpty=0}) ${message} ${exception:format=tostring}" />
		<target xsi:type="EventLog" name="eventLog"
				layout="[${longdate}] [${level}] [${logger}] (${event-properties:item=EventId:whenEmpty=0}) ${message} ${exception:format=tostring}" />
	</targets>

	<!-- rules to map from logger name to target -->
	<rules>
		<!-- All logs, including from Microsoft -->
		<logger name="*" minlevel="Debug" writeTo="latestLog,console,eventLog" />

		<logger name="System.*" finalMinLevel="Warn" />
		<logger name="Microsoft.*" finalMinLevel="Warn" />
	</rules>
</nlog>